PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/urban-elegance

# JWT Secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Admin Configuration
ADMIN_PASSWORD=adminpassword123!
